[color]
    ui = auto
[user]
    email = andreas@langenhagen.cc
    name = Andreas Langenhagen
[rebase]
    autostash = true
[rerere]
    enabled = true
[core]
    excludesfile = ~/.gitignore_global
    editor = vim
    pager = diff-so-fancy | less --tabs=1,5 -R
[gitreview]
    remote = origin
    username = andreasl
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[merge]
    tool = vimdiff
    conflictstyle = diff3
[mergetool]
    prompt = false
[init]
	defaultBranch = main

[includeIf "gitdir:~/wandel/"]
    path = ~/dotfiles/.gitconfig-work
